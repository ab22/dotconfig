{
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "edit_predictions": {
    "provider": "none"
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "git_panel": {
    "collapse_untracked_diff": false,
    "status_style": "label_color",
    "dock": "left",
    "button": true
  },
  "auto_signature_help": false,
  "icon_theme": "Catppuccin Mocha",
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_font_size": 12,
  "ensure_final_newline_on_save": true,
  "relative_line_numbers": "enabled",
  "remove_trailing_whitespace_on_save": true,
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font Mono",
    "font_size": 12
  },
  "theme": {
    "dark": "Catppuccin Mocha - No Italics",
    "light": "Catppuccin Mocha - No Italics",
    "mode": "system"
  },
  "ui_font_family": "JetBrainsMono Nerd Font",
  "ui_font_size": 14,
  "vim_mode": true,
  "wrap_guides": [90, 120],
  "minimap": {
    "show": "always"
  },
  "file_types": {
    "Shell Script": [".envrc*", "*.env*"],
    "Dockerfile": ["Dockerfile*"]
  }
}
